---
---

<section id="sobre-nosotros" class="py-20 sm:py-28 px-4 sm:px-6" style="background:#111124;">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Text side -->
      <div class="reveal">
        <span class="badge mb-5 inline-block">Sobre Nosotros</span>
        <h2 class="text-3xl sm:text-4xl font-black mb-6" style="font-family:'Orbitron',sans-serif; color:#F5F5F5;">
          Artesanía Digital<br />
          <span class="gradient-text">Con Alma</span>
        </h2>

        <p class="text-base leading-relaxed mb-5" style="color:#A0A0A0;">
          Minero3DPrinter nació de la pasión por la impresión 3D y el mundo geek. Desde Puertollano,
          Ciudad Real, damos vida a personajes de anime, videojuegos y fantasía con una dedicación que
          se nota en cada capa impresa.
        </p>
        <p class="text-base leading-relaxed mb-8" style="color:#A0A0A0;">
          <span class="font-semibold" style="color:#F5F5F5;">Cada pieza es única</span>, impresa con
          pasión y atención al detalle. No somos una fábrica — somos artesanos digitales que aman lo
          que hacen.
        </p>

        <!-- Highlights -->
        <ul class="space-y-3 mb-8">
          {[
            { icon: '📍', text: 'Ubicados en Puertollano, Ciudad Real' },
            { icon: '🇪🇸', text: 'Envío a toda España' },
            { icon: '🛠️', text: 'Encargos personalizados al detalle' },
            { icon: '⭐', text: 'Materiales de calidad premium' },
          ].map(item => (
            <li class="flex items-center gap-3">
              <span class="text-xl" role="img" aria-hidden="true">{item.icon}</span>
              <span class="text-sm" style="color:#A0A0A0;">{item.text}</span>
            </li>
          ))}
        </ul>

        <!-- Social links -->
        <div class="flex flex-wrap gap-3">
          <a
            href="https://www.instagram.com/minero3dprinter"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary inline-flex items-center gap-2 text-sm py-2 px-4"
            aria-label="Seguir en Instagram @minero3dprinter"
          >
            <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
            @minero3dprinter
          </a>

          <a
            href="https://wa.me/34679244719"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-whatsapp inline-flex items-center gap-2 text-sm py-2 px-4"
            aria-label="Contactar por WhatsApp"
          >
            <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
        </div>
      </div>

      <!-- Visual side -->
      <div class="reveal reveal-delay-2">
        <div
          class="rounded-2xl p-8 sm:p-10 relative overflow-hidden"
          style="background:linear-gradient(135deg,#161630,#1A1A3A); border:1px solid rgba(212,160,23,0.15);"
        >
          <!-- Decorative glow -->
          <div
            class="absolute top-0 right-0 w-48 h-48 rounded-full pointer-events-none"
            style="background:radial-gradient(circle,rgba(212,160,23,0.12),transparent 70%); transform:translate(30%,-30%);"
            aria-hidden="true"
          ></div>

          <div class="text-center mb-8">
            <span class="text-6xl sm:text-7xl" role="img" aria-label="Impresora 3D">🖨️</span>
          </div>

          <blockquote class="text-center">
            <p class="text-lg sm:text-xl font-medium leading-relaxed mb-4" style="color:#F5F5F5; font-style:italic;">
              "Cada pieza es única, impresa con pasión y atención al detalle."
            </p>
            <footer class="text-sm font-bold" style="color:#D4A017; font-family:'Orbitron',sans-serif;">
              — Minero3DPrinter
            </footer>
          </blockquote>

          <!-- Stats -->
          <div class="grid grid-cols-2 gap-4 mt-8 pt-8" style="border-top:1px solid rgba(42,42,74,0.8);">
            <div class="text-center">
              <div class="text-2xl font-black mb-1" style="font-family:'Orbitron',sans-serif; color:#008B8B;">Puertollano</div>
              <div class="text-xs" style="color:#A0A0A0;">Ciudad Real, España</div>
            </div>
            <div class="text-center" style="border-left:1px solid rgba(42,42,74,0.8);">
              <div class="text-2xl font-black mb-1" style="font-family:'Orbitron',sans-serif; color:#D4A017;">Artesanal</div>
              <div class="text-xs" style="color:#A0A0A0;">Hecho con amor</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="section-divider"></div>
