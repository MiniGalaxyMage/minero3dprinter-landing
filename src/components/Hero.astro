---
---

<section id="hero" class="hero-bg grid-lines relative min-h-screen flex items-center justify-center overflow-hidden pt-16">

  <!-- Floating glow orbs -->
  <div
    class="orb-float absolute top-1/4 left-[10%] w-72 h-72 rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(212,160,23,0.18) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>
  <div
    class="orb-float-rev absolute bottom-1/4 right-[8%] w-96 h-96 rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(0,139,139,0.15) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>
  <div
    class="absolute top-[60%] left-[60%] w-48 h-48 rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(212,160,23,0.08) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

    <!-- Badge -->
    <div class="flex justify-center mb-6 reveal">
      <span class="badge">✦ Artesanía 3D en Puertollano</span>
    </div>

    <!-- Main title -->
    <h1
      class="reveal reveal-delay-1 text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black leading-tight mb-6"
      style="font-family:'Orbitron',sans-serif;"
    >
      Transformamos Tus<br />
      <span class="gradient-text">Sueños en Realidad 3D</span>
    </h1>

    <!-- Subtitle -->
    <p
      class="reveal reveal-delay-2 text-lg sm:text-xl max-w-2xl mx-auto mb-10"
      style="color:#A0A0A0; font-family:'Inter',sans-serif;"
    >
      Figuras, bustos y accesorios únicos impresos en 3D.<br class="hidden sm:block" />
      Diseño artesanal en Puertollano — cada pieza, una obra de arte.
    </p>

    <!-- CTAs -->
    <div class="reveal reveal-delay-3 flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a href="#catalogo" class="btn-primary text-sm w-full sm:w-auto text-center">
        Ver Catálogo
      </a>
      <a href="#encargos" class="btn-secondary text-sm w-full sm:w-auto text-center">
        Pedir Encargo
      </a>
    </div>

    <!-- Stats row -->
    <div class="reveal reveal-delay-4 mt-16 grid grid-cols-3 gap-6 max-w-lg mx-auto">
      <div class="text-center">
        <div class="text-2xl sm:text-3xl font-black" style="font-family:'Orbitron',sans-serif; color:#D4A017;">+100</div>
        <div class="text-xs mt-1" style="color:#A0A0A0;">Piezas creadas</div>
      </div>
      <div class="text-center" style="border-left:1px solid #2A2A4A; border-right:1px solid #2A2A4A;">
        <div class="text-2xl sm:text-3xl font-black" style="font-family:'Orbitron',sans-serif; color:#008B8B;">5+</div>
        <div class="text-xs mt-1" style="color:#A0A0A0;">Categorías</div>
      </div>
      <div class="text-center">
        <div class="text-2xl sm:text-3xl font-black" style="font-family:'Orbitron',sans-serif; color:#D4A017;">🇪🇸</div>
        <div class="text-xs mt-1" style="color:#A0A0A0;">Envío nacional</div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2" aria-hidden="true">
    <span class="text-xs" style="color:#A0A0A0; font-family:'Inter',sans-serif;">Explorar</span>
    <div class="w-px h-8" style="background: linear-gradient(180deg, #D4A017, transparent);"></div>
  </div>
</section>
