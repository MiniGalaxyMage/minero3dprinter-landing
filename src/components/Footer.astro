---
const year = new Date().getFullYear();
---

<footer style="background:#0A0A18; border-top:1px solid rgba(42,42,74,0.8);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">

      <!-- Brand column -->
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <img src="/logo.svg" alt="Minero3DPrinter" class="h-8 w-8" />
          <div class="leading-none">
            <span class="block text-xs font-black tracking-widest" style="font-family:'Orbitron',sans-serif; color:#D4A017;">MINERO</span>
            <span class="block text-xs font-bold tracking-widest" style="font-family:'Orbitron',sans-serif; color:#008B8B;">3D PRINTER</span>
          </div>
        </div>
        <p class="text-sm leading-relaxed mb-4" style="color:#A0A0A0;">
          Impresión 3D artesanal en Puertollano, Ciudad Real. Figuras, bustos y accesorios únicos para geeks y gamers.
        </p>
        <div class="flex gap-3">
          <a
            href="https://www.instagram.com/minero3dprinter"
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded-lg flex items-center justify-center transition-all duration-200"
            style="background:rgba(42,42,74,0.6); border:1px solid rgba(42,42,74,0.8); color:#A0A0A0;"
            aria-label="Instagram @minero3dprinter"
            onmouseover="this.style.borderColor='rgba(212,160,23,0.5)'; this.style.color='#D4A017';"
            onmouseout="this.style.borderColor='rgba(42,42,74,0.8)'; this.style.color='#A0A0A0';"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a
            href="https://wa.me/34679244719"
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded-lg flex items-center justify-center transition-all duration-200"
            style="background:rgba(42,42,74,0.6); border:1px solid rgba(42,42,74,0.8); color:#A0A0A0;"
            aria-label="WhatsApp"
            onmouseover="this.style.borderColor='rgba(37,211,102,0.5)'; this.style.color='#25D366';"
            onmouseout="this.style.borderColor='rgba(42,42,74,0.8)'; this.style.color='#A0A0A0';"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Nav columns -->
      <div>
        <h4 class="text-sm font-bold mb-4 tracking-widest uppercase" style="font-family:'Orbitron',sans-serif; color:#F5F5F5;">Catálogo</h4>
        <ul class="space-y-2">
          {[
            { href: '#cat-bustos', label: 'Bustos y Figuras' },
            { href: '#cat-anime', label: 'Anime & Manga' },
            { href: '#cat-gaming', label: 'Accesorios Gaming' },
            { href: '#cat-decoracion', label: 'Decoración' },
            { href: '#cat-custom', label: 'Encargos Custom' },
          ].map(link => (
            <li>
              <a href={link.href} class="text-sm transition-colors duration-200 hover:text-primary" style="color:#A0A0A0;">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-bold mb-4 tracking-widest uppercase" style="font-family:'Orbitron',sans-serif; color:#F5F5F5;">Empresa</h4>
        <ul class="space-y-2">
          {[
            { href: '#sobre-nosotros', label: 'Sobre Nosotros' },
            { href: '#como-funciona', label: 'Cómo Funciona' },
            { href: '#encargos', label: 'Pedir Encargo' },
            { href: '/privacidad', label: 'Política de Privacidad' },
            { href: '/legal', label: 'Aviso Legal' },
          ].map(link => (
            <li>
              <a href={link.href} class="text-sm transition-colors duration-200 hover:text-primary" style="color:#A0A0A0;">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-bold mb-4 tracking-widest uppercase" style="font-family:'Orbitron',sans-serif; color:#F5F5F5;">Contacto</h4>
        <ul class="space-y-3">
          <li class="flex items-start gap-2">
            <span class="text-base mt-0.5" aria-hidden="true">📍</span>
            <span class="text-sm" style="color:#A0A0A0;">Puertollano, Ciudad Real<br />Castilla-La Mancha, España</span>
          </li>
          <li>
            <a
              href="https://wa.me/34679244719"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-sm transition-colors duration-200"
              style="color:#A0A0A0;"
            >
              <span aria-hidden="true">📱</span>
              +34 679 244 719
            </a>
          </li>
          <li>
            <a
              href="https://www.instagram.com/minero3dprinter"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-sm transition-colors duration-200"
              style="color:#A0A0A0;"
            >
              <span aria-hidden="true">📸</span>
              @minero3dprinter
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4" style="border-top:1px solid rgba(42,42,74,0.8);">
      <p class="text-xs" style="color:#A0A0A0;">
        © {year} Minero3DPrinter. Todos los derechos reservados.
      </p>
      <div class="flex gap-4 text-xs">
        <a href="/privacidad" class="transition-colors duration-200" style="color:#A0A0A0;" onmouseover="this.style.color='#D4A017'" onmouseout="this.style.color='#A0A0A0'">
          Política de Privacidad
        </a>
        <span style="color:#2A2A4A;">|</span>
        <a href="/legal" class="transition-colors duration-200" style="color:#A0A0A0;" onmouseover="this.style.color='#D4A017'" onmouseout="this.style.color='#A0A0A0'">
          Aviso Legal
        </a>
      </div>
    </div>
  </div>
</footer>
