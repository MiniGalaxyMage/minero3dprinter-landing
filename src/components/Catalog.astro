---
const WA_BASE = 'https://wa.me/34679244719?text=';

const products = [
  // Bustos y Figuras
  {
    name: 'Busto Villano Premium',
    category: 'bustos',
    categoryLabel: 'Bustos y Figuras',
    price: '30€',
    emoji: '🎭',
    msg: 'Hola!%20Me%20interesa%20el%20Busto%20Villano%20Premium',
  },
  {
    name: 'Geralt de Rivia (The Witcher)',
    category: 'bustos',
    categoryLabel: 'Bustos y Figuras',
    price: '35€',
    emoji: '⚔️',
    msg: 'Hola!%20Me%20interesa%20la%20figura%20de%20Geralt',
  },
  // Anime & Manga
  {
    name: 'Cuadro One Piece (Skull)',
    category: 'anime',
    categoryLabel: 'Anime & Manga',
    price: '25€',
    emoji: '☠️',
    msg: 'Hola!%20Me%20interesa%20el%20Cuadro%20One%20Piece',
  },
  {
    name: 'Going Merry (One Piece)',
    category: 'anime',
    categoryLabel: 'Anime & Manga',
    price: '30€',
    emoji: '⛵',
    msg: 'Hola!%20Me%20interesa%20el%20Going%20Merry',
  },
  {
    name: 'Figura Luffy Dorada',
    category: 'anime',
    categoryLabel: 'Anime & Manga',
    price: '25€',
    emoji: '👊',
    msg: 'Hola!%20Me%20interesa%20la%20Figura%20Luffy',
  },
  // Gaming
  {
    name: 'Soporte de Auriculares',
    category: 'gaming',
    categoryLabel: 'Accesorios Gaming',
    price: '15€',
    emoji: '🎧',
    msg: 'Hola!%20Me%20interesa%20el%20Soporte%20de%20Auriculares',
  },
  {
    name: 'Cenicero Anime',
    category: 'gaming',
    categoryLabel: 'Accesorios Gaming',
    price: '15€',
    emoji: '🌸',
    msg: 'Hola!%20Me%20interesa%20el%20Cenicero%20Anime',
  },
  // Decoración
  {
    name: 'Set Navidad (Belén 3D)',
    category: 'decoracion',
    categoryLabel: 'Decoración',
    price: '35€',
    emoji: '🎄',
    msg: 'Hola!%20Me%20interesa%20el%20Set%20Navidad',
  },
];

// Group by category
const bustos = products.filter(p => p.category === 'bustos');
const anime = products.filter(p => p.category === 'anime');
const gaming = products.filter(p => p.category === 'gaming');
const decoracion = products.filter(p => p.category === 'decoracion');

const sections = [
  { id: 'bustos', label: 'Bustos y Figuras', emoji: '🎭', items: bustos },
  { id: 'anime', label: 'Anime & Manga', emoji: '⚓', items: anime },
  { id: 'gaming', label: 'Accesorios Gaming', emoji: '🎧', items: gaming },
  { id: 'decoracion', label: 'Decoración', emoji: '🎄', items: decoracion },
];
---

<section id="catalogo" class="py-20 sm:py-28 px-4 sm:px-6" style="background:#0D0D1A;">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <span class="badge mb-4 inline-block">Catálogo</span>
      <h2 class="text-3xl sm:text-4xl font-black mb-4" style="font-family:'Orbitron',sans-serif; color:#F5F5F5;">
        Nuestros <span class="gradient-text">Productos</span>
      </h2>
      <p class="text-base max-w-xl mx-auto" style="color:#A0A0A0;">
        Cada pieza impresa con pasión y acabado artesanal. Haz clic en WhatsApp para reservar.
      </p>
    </div>

    <!-- Category sections -->
    {sections.map((section) => (
      <div id={`cat-${section.id}`} class="mb-16">
        <!-- Section label -->
        <div class="flex items-center gap-3 mb-8 reveal">
          <span class="text-2xl" role="img" aria-hidden="true">{section.emoji}</span>
          <h3 class="text-xl sm:text-2xl font-bold" style="font-family:'Orbitron',sans-serif; color:#F5F5F5;">
            {section.label}
          </h3>
          <div class="flex-1 h-px ml-2" style="background:linear-gradient(90deg,rgba(212,160,23,0.35),transparent);"></div>
        </div>

        <!-- Products grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
          {section.items.map((product, i) => (
            <article
              class={`card-glow overflow-hidden flex flex-col reveal reveal-delay-${Math.min(i + 1, 4)}`}
            >
              <!-- Placeholder image area -->
              <div
                class="relative flex items-center justify-center text-6xl sm:text-7xl py-10"
                style="background:linear-gradient(135deg,#111124,#1A1A3A);"
                aria-hidden="true"
              >
                <span role="img" aria-label={product.name}>{product.emoji}</span>
                <!-- Price badge -->
                <span
                  class="absolute top-3 right-3 text-xs font-bold px-2 py-1 rounded-md"
                  style="background:rgba(212,160,23,0.15); color:#D4A017; font-family:'Orbitron',sans-serif; border:1px solid rgba(212,160,23,0.3);"
                >
                  {product.price}
                </span>
              </div>

              <!-- Card body -->
              <div class="flex flex-col flex-1 p-4 gap-4">
                <div>
                  <p class="text-xs font-medium mb-1" style="color:#008B8B;">{product.categoryLabel}</p>
                  <h4 class="font-bold text-sm sm:text-base leading-snug" style="color:#F5F5F5; font-family:'Orbitron',sans-serif;">
                    {product.name}
                  </h4>
                </div>
                <div class="mt-auto">
                  <a
                    href={`${WA_BASE}${product.msg}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn-whatsapp w-full justify-center text-xs"
                    aria-label={`Reservar ${product.name} por WhatsApp`}
                  >
                    <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
                    </svg>
                    Reservar por WhatsApp
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    ))}

    <!-- Custom orders CTA -->
    <div id="cat-custom" class="reveal">
      <div
        class="rounded-2xl p-8 sm:p-12 text-center"
        style="background:linear-gradient(135deg,rgba(212,160,23,0.08),rgba(0,139,139,0.08)); border:1px solid rgba(212,160,23,0.2);"
      >
        <span class="text-5xl mb-4 block" role="img" aria-label="Encargo personalizado">✨</span>
        <h3 class="text-2xl sm:text-3xl font-black mb-3" style="font-family:'Orbitron',sans-serif; color:#F5F5F5;">
          Encargos Custom
        </h3>
        <p class="text-base mb-6 max-w-lg mx-auto" style="color:#A0A0A0;">
          ¿Tienes algo especial en mente? Diseñamos y fabricamos cualquier pieza según tus necesidades.
        </p>
        <a href="#encargos" class="btn-primary inline-block">
          Hacer un Encargo
        </a>
      </div>
    </div>
  </div>
</section>

<div class="section-divider"></div>
