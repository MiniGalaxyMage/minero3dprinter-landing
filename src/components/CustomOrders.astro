---
---

<section id="encargos" class="py-20 sm:py-28 px-4 sm:px-6" style="background:#0D0D1A;">
  <div class="max-w-5xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-14 reveal">
      <span class="badge mb-4 inline-block">Encargos</span>
      <h2 class="text-3xl sm:text-4xl font-black mb-4" style="font-family:'Orbitron',sans-serif; color:#F5F5F5;">
        ¿Tienes una Idea?<br />
        <span class="gradient-text">La Hacemos Realidad</span>
      </h2>
      <p class="text-base max-w-xl mx-auto" style="color:#A0A0A0;">
        Cuéntanos tu proyecto y recibirás respuesta en menos de 24 horas. Cualquier diseño, cualquier tamaño.
      </p>
    </div>

    <!-- Form card -->
    <div class="reveal">
      <div
        class="rounded-2xl p-6 sm:p-10"
        style="background:#161630; border:1px solid rgba(212,160,23,0.15);"
      >
        <form
          action="#"
          method="POST"
          enctype="multipart/form-data"
          class="grid grid-cols-1 sm:grid-cols-2 gap-5"
          novalidate
        >
          <!-- Nombre -->
          <div class="sm:col-span-1">
            <label for="nombre" class="block text-sm font-medium mb-2" style="color:#F5F5F5; font-family:'Inter',sans-serif;">
              Nombre *
            </label>
            <input
              id="nombre"
              name="nombre"
              type="text"
              required
              placeholder="Tu nombre"
              class="form-input"
            />
          </div>

          <!-- Email -->
          <div class="sm:col-span-1">
            <label for="email" class="block text-sm font-medium mb-2" style="color:#F5F5F5; font-family:'Inter',sans-serif;">
              Email *
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              placeholder="tu@email.com"
              class="form-input"
            />
          </div>

          <!-- Teléfono -->
          <div class="sm:col-span-1">
            <label for="telefono" class="block text-sm font-medium mb-2" style="color:#F5F5F5; font-family:'Inter',sans-serif;">
              Teléfono
            </label>
            <input
              id="telefono"
              name="telefono"
              type="tel"
              placeholder="+34 600 000 000"
              class="form-input"
            />
          </div>

          <!-- Archivo -->
          <div class="sm:col-span-1">
            <label for="archivo" class="block text-sm font-medium mb-2" style="color:#F5F5F5; font-family:'Inter',sans-serif;">
              Archivo de referencia <span style="color:#A0A0A0;">(opcional)</span>
            </label>
            <div
              class="rounded-lg border border-dashed flex items-center justify-center px-4 py-3 gap-2 cursor-pointer"
              style="border-color:#2A2A4A; background:#1A1A3A;"
            >
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" style="color:#A0A0A0;">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              <span class="text-sm" style="color:#A0A0A0;">Adjuntar imagen o STL</span>
              <input
                id="archivo"
                name="archivo"
                type="file"
                accept=".jpg,.jpeg,.png,.gif,.stl,.obj,.pdf"
                class="absolute w-0 h-0"
                aria-label="Seleccionar archivo de referencia"
              />
            </div>
          </div>

          <!-- Descripción -->
          <div class="sm:col-span-2">
            <label for="descripcion" class="block text-sm font-medium mb-2" style="color:#F5F5F5; font-family:'Inter',sans-serif;">
              Descripción del encargo *
            </label>
            <textarea
              id="descripcion"
              name="descripcion"
              required
              rows="5"
              placeholder="Cuéntanos qué quieres imprimir: personaje, tamaño aproximado, colores, detalles especiales..."
              class="form-input resize-y"
              style="min-height:120px;"
            ></textarea>
          </div>

          <!-- Privacy notice -->
          <div class="sm:col-span-2">
            <p class="text-xs" style="color:#A0A0A0;">
              Al enviar este formulario aceptas nuestra
              <a href="/privacidad" class="underline" style="color:#D4A017;">política de privacidad</a>.
              Solo usamos tus datos para gestionar tu encargo.
            </p>
          </div>

          <!-- Submit -->
          <div class="sm:col-span-2 flex flex-col sm:flex-row gap-4 items-center justify-between">
            <a
              href="https://wa.me/34679244719?text=Hola!%20Quiero%20hacer%20un%20encargo%20personalizado"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-whatsapp w-full sm:w-auto justify-center"
            >
              <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
              </svg>
              Contactar por WhatsApp
            </a>
            <button type="submit" class="btn-primary w-full sm:w-auto text-center">
              Enviar Encargo
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<div class="section-divider"></div>
